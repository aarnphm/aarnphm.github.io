from typing import Any

class Mesh:
  devices: Any
  axis_names: Any
  def __init__(self, devices: Any, axis_names: Any) -> None: ...
  def __enter__(self) -> Mesh: ...
  def __exit__(self, exc_type: Any, exc: Any, traceback: Any) -> bool: ...

class PartitionSpec(tuple[Any, ...]):
  def __new__(cls, *parts: Any) -> PartitionSpec: ...

class NamedSharding:
  mesh: Mesh
  spec: PartitionSpec
  def __init__(self, mesh: Mesh, spec: PartitionSpec) -> None: ...
