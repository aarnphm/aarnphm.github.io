from typing import Any

class Array:
  shape: tuple[int, ...]
  dtype: str
  ndim: int
  size: int
  T: Array
  at: Any
  def __len__(self) -> int: ...
  def __iter__(self) -> Any: ...
  def __getitem__(self, index: Any) -> Array: ...
  def __float__(self) -> float: ...
  def __int__(self) -> int: ...
  def __bool__(self) -> bool: ...
  def reshape(self, *shape: Any) -> Array: ...
  def transpose(self, axes: Any = ...) -> Array: ...
  def swapaxes(self, axis1: int, axis2: int) -> Array: ...
  def astype(self, dtype: Any) -> Array: ...
  def squeeze(self, axis: Any = ...) -> Array: ...
  def sum(self, axis: Any = ..., keepdims: bool = ...) -> Array: ...
  def mean(self, axis: Any = ..., keepdims: bool = ...) -> Array: ...
  def block_until_ready(self) -> Array: ...
  def addressable_data(self, index: int) -> Array: ...
  def tolist(self) -> Any: ...
  def item(self) -> Any: ...
  def to(self, *args: Any, **kwargs: Any) -> Array: ...

def array(values: Any, dtype: Any = ...) -> Array: ...
def asarray(values: Any, dtype: Any = ...) -> Array: ...
def arange(start: Any, stop: Any = ..., step: Any = ..., dtype: Any = ...) -> Array: ...
def zeros(shape: Any, dtype: Any = ...) -> Array: ...
def ones(shape: Any, dtype: Any = ...) -> Array: ...
def full(shape: Any, fill_value: Any, dtype: Any = ...) -> Array: ...
def zeros_like(value: Any, dtype: Any = ...) -> Array: ...
def ones_like(value: Any, dtype: Any = ...) -> Array: ...
def full_like(value: Any, fill_value: Any, dtype: Any = ...) -> Array: ...
def matmul(left: Any, right: Any) -> Array: ...
def dot(left: Any, right: Any) -> Array: ...
def mean(value: Any, axis: Any = ..., keepdims: bool = ...) -> Array: ...
def sum(value: Any, axis: Any = ..., keepdims: bool = ...) -> Array: ...
def sqrt(value: Any) -> Array: ...
def tanh(value: Any) -> Array: ...
def exp(value: Any) -> Array: ...
def log(value: Any) -> Array: ...
def sin(value: Any) -> Array: ...
def cos(value: Any) -> Array: ...
def floor(value: Any) -> Array: ...
def maximum(left: Any, right: Any) -> Array: ...
def split(value: Any, indices_or_sections: Any, axis: int = ...) -> list[Array]: ...
def tril(value: Any, k: int = ...) -> Array: ...
def where(cond: Any, left: Any, right: Any) -> Array: ...
def swapaxes(value: Any, axis1: int, axis2: int) -> Array: ...
def transpose(value: Any, axes: Any = ...) -> Array: ...
def take(value: Any, indices: Any, axis: Any = ...) -> Array: ...
def take_along_axis(value: Any, indices: Any, axis: int) -> Array: ...
def squeeze(value: Any, axis: Any = ...) -> Array: ...

float32: str
float64: str
float16: str
int32: str
uint32: str
bool_: str
bool: str
pi: float
